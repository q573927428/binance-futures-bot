# Binance API 配置
# 请前往 https://www.binance.com/zh-CN/my/settings/api-management 创建API密钥
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here

# DeepSeek AI 配置 (可选)
# 请前往 https://platform.deepseek.com/api_keys 获取API密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com

# 配置编辑密码保护 (可选)
# 设置此密码后，编辑系统配置时需要输入密码
# 如果不设置或留空，则不启用密码保护
CONFIG_EDIT_PASSWORD=

# K线数据存储目录配置 (可选)
# 默认使用项目根目录下的 data/kline-simple 目录
# 如果服务器权限问题，可以设置此变量指定可写目录
# 例如: KLINE_DATA_DIR=/var/data/kline-simple
# KLINE_DATA_DIR=
