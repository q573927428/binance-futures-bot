var float[] tp1 = array.from(36.66186,657.0502493972908,71685.19200000001,634.509806012549,66435.751633926,66722.58780514888,66836.9496635204,66946.3665494215,94.51695069910552,92.8817856480125,91.02309821431864,2023.4002473087965,628.7610562287847,2036.1180603438725,621.204036339709,63135.771817211906,80.76095457042973)
var float[] tp2 = array.from(37.38072,667.7804987945816,73090.78400000001,640.539612025098,65948.50326785201,66453.77561029777,66606.59932704079,66692.833098843,96.14390139821104,94.793571296025,92.54619642863727,2049.240494617593,633.2621124575694,2070.4361206877447,626.388072679418,62416.843634423814,79.87190914085946)

var string[] directions = array.from("LONG","LONG","LONG","LONG","SHORT","SHORT","SHORT","SHORT","LONG","LONG","LONG","LONG","LONG","LONG","LONG","SHORT","SHORT")
var string[] symbols = array.from("HYPE/USDT","BNB/USDT","BTC/USDT","BNB/USDT","BTC/USDT","BTC/USDT","BTC/USDT","BTC/USDT","SOL/USDT","SOL/USDT","SOL/USDT","ETH/USDT","BNB/USDT","ETH/USDT","BNB/USDT","BTC/USDT","SOL/USDT")
var float[] pnl = array.from(15.92,-16.86,3.92,-5.94,-4.46,2.44,-2.52,-2.64,-19.66,9.70,18.80,-8.78,2.19,5.57,14.74,-9.57,-0.88)

