var string[] symbols = array.from("ETH/USDT","XAU/USDT","BNB/USDT","BNB/USDT","XAU/USDT","XAU/USDT","XAU/USDT","BTC/USDT","SOL/USDT","BNB/USDT","DOGE/USDT","BTC/USDT","BTC/USDT","DOGE/USDT","HYPE/USDT","BNB/USDT","BTC/USDT","BNB/USDT","BTC/USDT","BTC/USDT","BTC/USDT","BTC/USDT","SOL/USDT","SOL/USDT","SOL/USDT","ETH/USDT","BNB/USDT","ETH/USDT","BNB/USDT","BTC/USDT","SOL/USDT")
