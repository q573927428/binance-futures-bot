//@version=6
indicator("Trade History Dashboard", overlay=true, max_labels_count=500, max_lines_count=500)

// EMA 移动平均线 (根据 strategyMode 配置: medium_term)
emaFastPeriod = 50
emaSlowPeriod = 200
emaFastLine = ta.ema(close, emaFastPeriod)
emaSlowLine = ta.ema(close, emaSlowPeriod)

plot(emaFastLine, "EMA 50", color=color.blue, linewidth=2)
plot(emaSlowLine, "EMA 200", color=color.orange, linewidth=2)

// ====================== EMA50 偏离率 ======================
ema50Deviation = (close - emaFastLine) / emaFastLine * 100

// 分级颜色逻辑（核心优化）
color devColor =
     ema50Deviation > 2  ? color.red :
     ema50Deviation < -2 ? color.red :
     color.green

// 只保留一个标签（避免爆 label）
var label emaLabel = na

if barstate.islast
    label.delete(emaLabel)
    emaLabel := label.new(
        bar_index,
        high,
        "EMA50偏离: " + str.tostring(ema50Deviation, "#.##") + "%",
        style = label.style_label_right,
        color = devColor,
        textcolor = color.white,
        size = size.normal
    )

// ====================== 原始数据 ======================

